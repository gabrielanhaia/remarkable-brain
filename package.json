{
  "name": "rm-brain",
  "version": "0.1.0",
  "description": "Local-first second brain for reMarkable notebooks, searched through Claude Desktop",
  "license": "MIT",
  "author": "Gabriel Anhaia",
  "type": "module",
  "bin": { "rm-brain": "dist/cli.js" },
  "exports": "./dist/index.js",
  "files": ["dist", "web/dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "keywords": [
    "remarkable",
    "second-brain",
    "notes",
    "handwriting",
    "ocr",
    "claude",
    "mcp",
    "model-context-protocol",
    "local-first",
    "sqlite",
    "cli"
  ],
  "homepage": "https://github.com/gabrielanhaia/remarkable-brain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielanhaia/remarkable-brain.git"
  },
  "bugs": {
    "url": "https://github.com/gabrielanhaia/remarkable-brain/issues"
  },
  "scripts": {
    "build": "npm run build:web && npm run build:cli",
    "build:cli": "tsup src/cli.ts src/index.ts src/mcp/server.ts src/web/server.ts --format esm --clean",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "dev": "tsx src/cli.ts",
    "mcp": "tsx src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run typecheck && npm test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@clack/prompts": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "better-sqlite3": "^11.8.0",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.6"
  }
}
