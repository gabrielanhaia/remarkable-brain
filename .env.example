# Path to the local data home (default: ~/.rm-brain)
RM_BRAIN_HOME=
# Path/name of the rmapi binary — use the ddvk sync15 build (default: rmapi)
RMAPI_BIN=rmapi
# Path/name of the rmc binary that renders .rm v6 pages (default: rmc)
RMC_BIN=rmc
# Path/name of rsvg-convert, used for SVG->PNG (default: rsvg-convert)
RSVG_BIN=rsvg-convert
# Required only for `rm-brain sync` (extraction). Never commit this.
ANTHROPIC_API_KEY=
# Vision model for extraction (default: claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5
